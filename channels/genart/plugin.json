{
  "id": "com.mimir.genart",
  "name": "Generative Art",
  "description": "Gallery-grade algorithmic art rendered locally — no external APIs. Eight print styles across thirteen composition algorithms, saved as named galleries you can assign to different programs and displays, with static PNG output for e-ink and seamless animated WebP loops for LCD/OLED displays.",
  "version": "2.1.0",
  "type": "embedded",
  "entry_point": "channel.py",
  "class_name": "GenArtChannel",
  "icon": "shapes",
  "author": "Ryan Lane",
  "tags": ["generative", "art", "algorithmic", "bauhaus", "risograph", "eink", "animated"],
  "schemaVersion": "2.4",
  "settingsType": "advanced",
  "config": {
    "supports_upload": false,
    "supports_subchannels": true,
    "requires_api_key": false,
    "renders_locally": true
  },
  "requirements": {
    "python": ">=3.9",
    "dependencies": ["fastapi", "pillow"]
  },
  "user_data_dirs": ["data"],
  "ui": [
    {
      "route": "/genart",
      "element": "x-genart-manager",
      "moduleUrl": "/api/channels/com.mimir.genart/ui/manage.esm.js",
      "nav": {
        "label": "Generative Art",
        "icon": "shapes"
      },
      "renderMode": "element"
    }
  ],
  "endpoints": [
    { "path": "/manifest",                 "method": "GET",    "description": "Channel manifest" },
    { "path": "/subchannels",               "method": "GET",    "description": "List configured galleries" },
    { "path": "/subchannels",               "method": "POST",   "description": "Create a new gallery" },
    { "path": "/subchannels/{id}",          "method": "GET",    "description": "Get a gallery config" },
    { "path": "/subchannels/{id}",          "method": "PUT",    "description": "Update a gallery config" },
    { "path": "/subchannels/{id}",          "method": "DELETE", "description": "Delete a gallery" },
    { "path": "/subchannels/{id}/preview",  "method": "GET",    "description": "Render a preview of a saved gallery" },
    { "path": "/preview",                   "method": "POST",   "description": "Render a preview from an unsaved (draft) config" },
    { "path": "/request-image",             "method": "POST",   "description": "Render a piece from the resolved gallery at display resolution" },
    { "path": "/status",                    "method": "GET",    "description": "Galleries, styles, algorithms, last render info" }
  ]
}
